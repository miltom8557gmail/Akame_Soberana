<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="#050505" android:padding="20dp">

    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="AKAME FORGE: CLOUD EDITION" android:textColor="#00FFCC"
        android:gravity="center" android:textSize="14sp" android:textStyle="bold"/>

    <EditText android:id="@+id/input_ideia" android:layout_width="match_parent" android:layout_height="120dp"
        android:hint="Ex: Crie um filme de 30s estilo Cyberpunk ou converta este vídeo em Deepfake..."
        android:textColor="#FFFFFF" android:textColorHint="#444444" android:background="#111111"
        android:gravity="top" android:padding="15dp" android:layout_marginTop="20dp"/>

    <GridLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:columnCount="2" android:layout_marginTop="20dp">
        <Button android:id="@+id/btn_deepfake" android:text="🎥 DEEPFAKE" android:layout_columnWeight="1" android:backgroundTint="#BD00FF"/>
        <Button android:id="@+id/btn_ffmpeg" android:text="✂️ FFMPEG" android:layout_columnWeight="1" android:backgroundTint="#FFCC00"/>
        <Button android:id="@+id/btn_traduz" android:text="🌍 TRADUÇÃO" android:layout_columnWeight="1" android:backgroundTint="#00AAFF"/>
        <Button android:id="@+id/btn_chat" android:text="🤖 CHATBOT" android:layout_columnWeight="1" android:backgroundTint="#00FFCC"/>
    </GridLayout>

    <Button android:id="@+id/btn_forjar" android:layout_width="match_parent" android:layout_height="60dp"
        android:text="⚡ FORJAR NA NUVEM" android:layout_marginTop="20dp" android:backgroundTint="#FF003C"/>

    <ScrollView android:layout_width="match_parent" android:layout_height="match_parent" android:layout_marginTop="10dp">
        <TextView android:id="@+id/log_cloud" android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="> Aguardando ordem criativa..." android:textColor="#00FF00" android:typeface="monospace" android:textSize="10sp"/>
    </ScrollView>
</LinearLayout>
