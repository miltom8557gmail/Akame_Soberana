<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="#020202" android:padding="20dp">

    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="AKAME OMNI: CLOUD BACKUP" android:textColor="#4285F4"
        android:gravity="center" android:textSize="16sp" android:textStyle="bold"/>

    <Button android:id="@+id/btn_google_backup" android:layout_width="match_parent" android:layout_height="60dp"
        android:text="☁️ BACKUP PARA GOOGLE DRIVE" android:backgroundTint="#34A853"
        android:layout_marginTop="20dp"/>

    <TextView android:id="@+id/sync_status" android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="Status: Google Cloud Sincronizado" android:textColor="#FBBC05"
        android:gravity="center" android:layout_marginTop="10dp" android:textSize="12sp"/>

    <ScrollView android:layout_width="match_parent" android:layout_height="match_parent" android:layout_marginTop="20dp">
        <TextView android:id="@+id/log_terminal" android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="> Monitorando integridade local..." android:textColor="#00FFCC" android:typeface="monospace"/>
    </ScrollView>
</LinearLayout>
