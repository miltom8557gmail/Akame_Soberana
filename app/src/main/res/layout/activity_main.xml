<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="#020202">

    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="AKAME OMNI-LINK | MESTRE MILTOM" android:textColor="#00FFCC"
        android:gravity="center" android:padding="10dp" android:background="#0A0A0A" android:textSize="12sp"/>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:background="#111">
        <Button android:id="@+id/tab_chat" android:text="CHAT" android:layout_width="0dp" android:layout_weight="1" style="?android:attr/borderlessButtonStyle" android:textColor="#FFF"/>
        <Button android:id="@+id/tab_projetos" android:text="PROJETOS" android:layout_width="0dp" android:layout_weight="1" style="?android:attr/borderlessButtonStyle" android:textColor="#FFF"/>
    </LinearLayout>

    <FrameLayout android:layout_width="match_parent" android:layout_height="match_parent" android:padding="10dp">
        <LinearLayout android:id="@+id/view_projetos" android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:visibility="visible">
            <Button android:id="@+id/btn_novo_projeto" android:text="+ NOVO PROJETO (NUVEM)" android:layout_width="match_parent" android:layout_height="wrap_content" android:backgroundTint="#BD00FF"/>
            <ListView android:id="@+id/list_projetos" android:layout_width="match_parent" android:layout_height="200dp" android:divider="#333" android:dividerHeight="1dp"/>
            <VideoView android:id="@+id/video_preview" android:layout_width="match_parent" android:layout_height="180dp" android:background="#000" android:layout_marginTop="10dp"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/view_chat" android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:visibility="gone">
            <ScrollView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1">
                <TextView android:id="@+id/chat_history" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="#00FF00" android:typeface="monospace"/>
            </ScrollView>
            <EditText android:id="@+id/input_ordem" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Comando para a Akame..." android:background="#222" android:padding="12dp" android:textColor="#FFF"/>
        </LinearLayout>
    </FrameLayout>
</LinearLayout>
