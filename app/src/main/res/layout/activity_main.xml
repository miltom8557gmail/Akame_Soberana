<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="#020202" android:padding="10dp">

    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="AKAME ORIGINAL: NÚCLEO INTELIGENTE" android:textColor="#00FFCC"
        android:gravity="center" android:padding="10dp" android:textStyle="bold"/>

    <EditText android:id="@+id/input_ordem" android:layout_width="match_parent" android:layout_height="200dp"
        android:hint="Dê uma ordem complexa (Criar código, roteiro, análise...)" 
        android:background="#111" android:textColor="#FFF" android:gravity="top" android:padding="15dp"/>

    <Button android:id="@+id/btn_enviar" android:layout_width="match_parent" android:layout_height="60dp"
        android:text="EXECUTAR PENSAMENTO" android:backgroundTint="#FF003C" android:layout_marginTop="10dp"/>

    <TextView android:id="@+id/status" android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="Aguardando Mestre..." android:textColor="#00FF00" android:layout_marginTop="10dp" android:typeface="monospace"/>
</LinearLayout>
