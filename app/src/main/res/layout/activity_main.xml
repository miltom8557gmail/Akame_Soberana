<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="#020202">

    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="AKAME OMNI-LINK | [miltom.jose8557]" android:textColor="#00FFCC"
        android:gravity="center" android:padding="8dp" android:textStyle="bold" android:background="#0A0A0A"/>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:background="#111111">
        <Button android:id="@+id/tab_chat" android:text="CHAT" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" style="?android:attr/borderlessButtonStyle" android:textColor="#888"/>
        <Button android:id="@+id/tab_projetos" android:text="PROJETOS" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" style="?android:attr/borderlessButtonStyle" android:textColor="#FFFFFF"/>
    </LinearLayout>

    <FrameLayout android:id="@+id/content_frame" android:layout_width="match_parent" android:layout_height="match_parent" android:padding="10dp">
        
        <LinearLayout android:id="@+id/layout_projetos" android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:visibility="visible">
            <Button android:id="@+id/btn_novo" android:text="+ NOVO PROJETO IMAGINAÇÃO" android:layout_width="match_parent" android:layout_height="wrap_content" android:backgroundTint="#BD00FF" android:textColor="#FFF"/>
            
            <ListView android:id="@+id/list_projetos" android:layout_width="match_parent" android:layout_height="150dp" android:divider="#333" android:dividerHeight="1dp"/>

            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="> PREVIEW DE SAÍDA:" android:textColor="#00FFCC" android:textSize="10sp" android:layout_marginTop="10dp" android:typeface="monospace"/>
            
            <ImageView android:id="@+id/img_preview" android:layout_width="match_parent" android:layout_height="150dp" android:scaleType="centerCrop" android:background="#0A0A0A" android:visibility="visible" android:layout_marginTop="5dp"/>
            
            <VideoView android:id="@+id/video_preview" android:layout_width="match_parent" android:layout_height="150dp" android:visibility="gone" android:layout_marginTop="5dp"/>

            <Button android:id="@+id/btn_atualizar" android:text="🔄 ATUALIZAR STATUS (TERMUX)" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:backgroundTint="#111"/>
        </LinearLayout>
    </FrameLayout>
</LinearLayout>
