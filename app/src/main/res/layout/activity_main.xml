<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="#020202" android:padding="20dp">

    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="NÚCLEO AKAME: PROTOCOLO FÊNIX" android:textColor="#FF003C"
        android:gravity="center" android:textSize="16sp" android:textStyle="bold"/>

    <Button android:id="@+id/btn_restore" android:layout_width="match_parent" android:layout_height="70dp"
        android:text="🔥 RESTAURAR SISTEMA COMPLETO" android:backgroundTint="#FF003C"
        android:layout_marginTop="20dp" android:layout_marginBottom="20dp"/>

    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#333333"/>

    <GridLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:columnCount="2" android:layout_marginTop="20dp">
        <Button android:id="@+id/btn_deploy" android:text="DEPLOY" android:layout_columnWeight="1"/>
        <Button android:id="@+id/btn_sync" android:text="SYNC" android:layout_columnWeight="1"/>
    </GridLayout>

    <ScrollView android:layout_width="match_parent" android:layout_height="match_parent" android:layout_marginTop="15dp">
        <TextView android:id="@+id/log_terminal" android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="> Aguardando instruções..." android:textColor="#00FFCC" android:typeface="monospace"/>
    </ScrollView>
</LinearLayout>
