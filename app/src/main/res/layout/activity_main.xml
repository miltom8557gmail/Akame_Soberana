<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="#020202" android:padding="10dp">

    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="AKAME NEURAL LINK v11.0" android:textColor="#00FFCC" 
        android:gravity="center" android:textSize="14sp" android:layout_marginBottom="10dp"/>

    <ScrollView android:id="@+id/chat_scroll" android:layout_width="match_parent" 
        android:layout_height="0dp" android:layout_weight="1" android:background="#080808">
        <TextView android:id="@+id/chat_display" android:layout_width="match_parent" 
            android:layout_height="wrap_content" android:padding="10dp"
            android:text="> Aguardando sincronia com Akame PhD..." android:textColor="#00FF00" 
            android:typeface="monospace" android:textSize="12sp"/>
    </ScrollView>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:layout_marginTop="10dp">
        <EditText android:id="@+id/chat_input" android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:hint="Digite sua ordem..." android:textColor="#FFFFFF"
            android:textColorHint="#444444" android:background="#111111" android:padding="12dp"/>
        <Button android:id="@+id/btn_send" android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="ENVIAR" android:backgroundTint="#BD00FF" android:textColor="#FFFFFF"/>
    </LinearLayout>
</LinearLayout>
