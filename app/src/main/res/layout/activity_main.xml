<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#050505">

    <ImageView
        android:id="@+id/akame_visual_core"
        android:layout_width="match_parent"
        android:layout_height="320dp"
        android:scaleType="centerCrop"
        android:src="@android:drawable/ic_menu_gallery"
        android:alpha="0.9"/>

    <TextView
        android:id="@+id/title_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="AKAME OMNI v10.8"
        android:textColor="#00FFCC"
        android:textSize="20sp"
        android:layout_below="@id/akame_visual_core"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="10dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_below="@id/title_text"
        android:padding="15dp">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" 
            android:text="● CLOUD UBUNTU: ONLINE" android:textColor="#BD00FF"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" 
            android:text="● OLLAMA/FFMPEG: CLOUD ACTIVE" android:textColor="#BD00FF"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" 
            android:text="● HUMAN PROFILE: SYNCED" android:textColor="#00FFCC"/>
    </LinearLayout>
</RelativeLayout>
